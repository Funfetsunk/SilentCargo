  <item nodeId="node-133">
    <command xml:space="preserve">n</command>
    <result xml:space="preserve">Medbay&#x000A;Soft white medical lights fill the bay. The diagnostic bed sits beneath a now-active terminal, its screen glowing with standby data.&#x000A;&#x000A;Exits: north, south.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-134"/>
    </children>
  </item>
  <item nodeId="node-134">
    <command xml:space="preserve">view sleep data</command>
    <result xml:space="preserve">Sleep Cycle Data:&#x000A;&#x000A;REM cycles inconsistent across all crew.&#x000A;Sleep interruptions recorded at irregular intervals.&#x000A;&#x000A;Deeper diagnostic data available.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-135"/>
    </children>
  </item>
  <item nodeId="node-135">
    <command xml:space="preserve">view crew status</command>
    <result xml:space="preserve">Crew Status Summary:&#x000A;&#x000A;All crew members show elevated stress indicators.&#x000A;Sleep efficiency below recommended levels.&#x000A;No physical abnormalities detected.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-136"/>
    </children>
  </item>
  <item nodeId="node-136">
    <command xml:space="preserve">view diagnostic data</command>
    <result xml:space="preserve">Accessing raw medical datasets...&#x000A;&#x000A;Dataset: Human_Response_Test_A&#x000A;Dataset: Sleep_Cycle_Adjustment_03&#x000A;Dataset: Environmental_Variable_Trial&#x000A;&#x000A;&#x000A;One dataset remains active.&#x000A;&#x000A;&gt;</result>
