  <item nodeId="node-236">
    <command xml:space="preserve">n</command>
    <result xml:space="preserve">Medbay&#x000A;Soft white medical lights fill the bay. The diagnostic bed sits beneath a now-active terminal, its screen glowing with standby data.&#x000A;&#x000A;Exits: north, south.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-237"/>
    </children>
  </item>
  <item nodeId="node-237">
    <command xml:space="preserve">n</command>
    <result xml:space="preserve">Navigation Console&#x000A;The navigation station glows with restored power. Course data, comms status, and telemetry scroll quietly across the active displays.&#x000A;&#x000A;Exits: north, south.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-238"/>
    </children>
  </item>
  <item nodeId="node-238">
    <command xml:space="preserve">n</command>
    <result xml:space="preserve">Bridge&#x000A;The bridge is alive with low light from reawakened consoles. Status displays glow across the command stations while the stars remain cold beyond the forward port.&#x000A;&#x000A;Exits: south.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-239"/>
    </children>
  </item>
  <item nodeId="node-239">
    <command xml:space="preserve">use terminal</command>
    <result xml:space="preserve">The communications terminal activates. A transmission log appears on the screen.&#x000A;&#x000A;Available options:&#x000A;- view transmission log&#x000A;- view outgoing messages&#x000A;- view system response&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-240"/>
    </children>
  </item>
  <item nodeId="node-240">
    <command xml:space="preserve">view transmission log</command>
    <result xml:space="preserve">Transmission Log:&#x000A;&#x000A;Outgoing distress signal - FAILED&#x000A;Outgoing distress signal - FAILED&#x000A;Outgoing distress signal - FAILED&#x000A;&#x000A;&#x000A;No successful transmissions recorded.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-241"/>
    </children>
  </item>
  <item nodeId="node-241">
    <command xml:space="preserve">view outgoing messages</command>
    <result xml:space="preserve">Outgoing Messages:&#x000A;&#x000A;Draft message:&#x000A;"Distress signal. Systems compromised. Request immediate assistance."&#x000A;&#x000A;Status: NOT SENT&#x000A;&#x000A;&#x000A;Second draft:&#x000A;"Navigation unstable. Crew experiencing irregular conditions."&#x000A;&#x000A;Status: NOT SENT&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
