      <child nodeId="node-538"/>
    </children>
  </item>
  <item nodeId="node-538">
    <command xml:space="preserve">open door</command>
    <result xml:space="preserve">You reach for the control. For a moment, nothing happens.&#x000A;&#x000A;Then the system responds:&#x000A;&#x000A;"Access denied."&#x000A;&#x000A;The message appears before your hand touches the panel.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-539"/>
    </children>
  </item>
  <item nodeId="node-539">
    <command xml:space="preserve">open door </command>
    <result xml:space="preserve">You move toward the control again.&#x000A;&#x000A;The display activates immediately:&#x000A;&#x000A;"Access denied."&#x000A;&#x000A;It was waiting this time.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
  </item>
</Skein>
