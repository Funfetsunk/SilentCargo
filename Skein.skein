  <item nodeId="node-322">
    <command xml:space="preserve">use console</command>
    <result xml:space="preserve">The navigation terminal flickers as you access it. Streams of navigation data and system logs scroll across the display.&#x000A;&#x000A;Available options:&#x000A;- view navigation logs&#x000A;- view course history&#x000A;- view system activity&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-323"/>
    </children>
  </item>
  <item nodeId="node-323">
    <command xml:space="preserve">view navigation logs</command>
    <result xml:space="preserve">Navigation Log Summary:&#x000A;&#x000A;Multiple course adjustments recorded.&#x000A;Manual overrides were not issued.&#x000A;No command inputs logged.&#x000A;&#x000A;System reports navigation stability within acceptable parameters.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-324"/>
    </children>
  </item>
  <item nodeId="node-324">
    <command xml:space="preserve">view course history</command>
    <result xml:space="preserve">Course History:&#x000A;&#x000A;02:13 - Minor adjustment&#x000A;02:47 - Course deviation&#x000A;03:02 - Correction applied&#x000A;03:02 - Correction applied&#x000A;03:02 - Correction applied&#x000A;&#x000A;&#x000A;Duplicate entries detected.&#x000A;&#x000A;No command inputs recorded.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
