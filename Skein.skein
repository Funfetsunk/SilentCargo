  <item nodeId="node-535">
    <command xml:space="preserve">x scratched warning</command>
    <result xml:space="preserve">The words are carved deep into the metal:&#x000A;&#x000A;"DON'T LET IT HEAR YOU"&#x000A;&#x000A;The cuts are uneven. Desperate.&#x000A;&#x000A;Someone took the time to leave this behind.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
