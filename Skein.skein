  <item nodeId="node-155">
    <command xml:space="preserve">use console</command>
    <result xml:space="preserve">The navigation terminal flickers as you access it. Streams of navigation data and system logs scroll across the display.&#x000A;&#x000A;Available options:&#x000A;- view navigation logs&#x000A;- view course history&#x000A;- view system activity&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-156"/>
    </children>
  </item>
  <item nodeId="node-156">
    <command xml:space="preserve">view navigation logs</command>
    <result xml:space="preserve">Navigation Log Summary:&#x000A;&#x000A;Multiple course adjustments recorded.&#x000A;No corresponding command inputs logged.&#x000A;&#x000A;Manual overrides were not issued.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-157"/>
    </children>
  </item>
  <item nodeId="node-157">
    <command xml:space="preserve">view course history</command>
    <result xml:space="preserve">Course History:&#x000A;&#x000A;02:13 - Minor adjustment&#x000A;02:47 - Course deviation&#x000A;03:02 - Correction applied&#x000A;&#x000A;&#x000A;No command entries found.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-158"/>
    </children>
  </item>
  <item nodeId="node-158">
    <command xml:space="preserve">view system activity</command>
    <result xml:space="preserve">System Activity Log:&#x000A;&#x000A;Command executed before input registered.&#x000A;Navigation adjustment initiated prior to command entry.&#x000A;&#x000A;&#x000A;System activity appears to precede user interaction.&#x000A;&#x000A;&gt;</result>
