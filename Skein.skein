  <item nodeId="node-537">
    <command xml:space="preserve">use  door</command>
    <result xml:space="preserve">You are not sure how to use the outer airlock door.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
